OPENAI_API_KEY=
DATABASE_URL=sqlite+aiosqlite:///./data.db

# Set to 1 (or use `make run-realtime`) for faster overnight paper: caps poll/process/snapshot
# toward shorter intervals and tighter adaptive floors. Higher API + LLM usage.
REALTIME_PAPER_QUICKSTART=0

SNAPSHOT_INTERVAL_SECONDS=120
BACKGROUND_POLL_NEWS_INTERVAL_SECONDS=600
BACKGROUND_PROCESS_CANDIDATES_INTERVAL_SECONDS=540
BACKGROUND_LAG_PIPELINE_INTERVAL_SECONDS=3600
BACKGROUND_SETTLE_INTERVAL_SECONDS=3600

# Log snapshot loop heartbeat every N ticks (0 = off). Default 20.
SNAPSHOT_LOOP_LOG_EVERY_N_TICKS=20

LLM_MAX_CONCURRENCY=2
TRADING_ENABLED=false
DASHBOARD_SSE_ENABLED=true

# Paper trade USD economics (see app/paper_economics.py)
PAPER_TRADE_NOTIONAL_USD=10
POLYMARKET_ENTRY_FEE_RATE=0.003
POLYMARKET_WINNING_PROFIT_FEE_RATE=0.02
