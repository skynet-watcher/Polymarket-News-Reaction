# ── Vercel Environment Variables ────────────────────────────────────────────
# Copy these into your Vercel project → Settings → Environment Variables.
# Values marked REQUIRED must be set before the app will work.
# Values marked OPTIONAL have sensible defaults.

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
# From Vercel dashboard → Storage → Create Database → Postgres.
# Vercel may auto-populate POSTGRES_URL_NON_POOLING / POSTGRES_URL when you
# link the DB to the project. The app supports those directly and also supports
# DATABASE_URL if you prefer to add it manually.
POSTGRES_URL_NON_POOLING=postgres://user:password@host/dbname?sslmode=require
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── OpenAI (REQUIRED for news signal generation) ─────────────────────────────
OPENAI_API_KEY=sk-...

# ── Cron security (RECOMMENDED) ──────────────────────────────────────────────
# Any random string.  Vercel passes this as  Authorization: Bearer <value>
# when calling your cron endpoints.  Use the same value in cron-job.org headers.
CRON_SECRET=change-me-to-something-random

# ── Trading thresholds (OPTIONAL — these are the defaults) ───────────────────
MIN_LIQUIDITY=1000.0
MAX_SPREAD=0.08
MIN_CONFIDENCE=0.90
MIN_VERIFIER_CONFIDENCE=0.85

# ── Disable SSE (streaming) — Vercel doesn't support persistent connections ──
DASHBOARD_SSE_ENABLED=false

# ── Turn off background loops (Vercel sets VERCEL=1 automatically) ───────────
# You do NOT need to set this — Vercel sets it for you.
# VERCEL=1
