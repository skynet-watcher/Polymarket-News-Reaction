{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 300
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "api/index.py" }
  ],
  "crons": [
    { "path": "/api/cron/sports/build-watchlist", "schedule": "0 0 * * *"    },
    { "path": "/api/cron/sports/poll",            "schedule": "* * * * *"    },
    { "path": "/api/cron/sports/settle",          "schedule": "*/5 * * * *"  }
  ]
}
