{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/index.py" }
  ],
  "crons": [
    { "path": "/api/cron/pipeline", "schedule": "0 8 * * *" },
    { "path": "/api/cron/settle",   "schedule": "0 20 * * *" }
  ]
}
